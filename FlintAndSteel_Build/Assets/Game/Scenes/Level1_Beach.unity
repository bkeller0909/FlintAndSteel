      objectReference: {fileID: 0}
    - target: {fileID: 320530506433659665, guid: a1c123b23fa093646a93015aa00ecc2d,
        type: 3}
      propertyPath: messageText.Array.data[3]
      value: ...What does that mean?
      objectReference: {fileID: 0}
    - target: {fileID: 320530506433659665, guid: a1c123b23fa093646a93015aa00ecc2d,
        type: 3}
      propertyPath: messageText.Array.data[4]
      value: I'm a cursed object, only a fool would pick me up. Just like your hook
        there, you're stuck with me forever now.
      objectReference: {fileID: 0}
